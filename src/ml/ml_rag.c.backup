/* PG function declarations */
PG_FUNCTION_INFO_V1(neurondb_chunk_text);
PG_FUNCTION_INFO_V1(neurondb_embed_text);
PG_FUNCTION_INFO_V1(neurondb_rank_documents);
PG_FUNCTION_INFO_V1(neurondb_transform_data);

/* ---- neurondb.chunk() ---- */
Datum
neurondb_chunk_text(PG_FUNCTION_ARGS)
{
	text	   *input_text;
	int32		chunk_size;
	int32		overlap;
	text	   *separator_text;
	char	   *input_str;
	char	   *separator;
	int			input_len;
	int			sep_len;
	int			num_chunks;
	int			start;
	int			chunk_count;
	Datum	   *chunk_datums;
	ArrayType  *result_array;

	/* Input arguments */
	input_text = PG_GETARG_TEXT_PP(0);
	chunk_size = PG_ARGISNULL(1) ? 512 : PG_GETARG_INT32(1);
	overlap    = PG_ARGISNULL(2) ? 128 : PG_GETARG_INT32(2);
	separator_text = PG_ARGISNULL(3) ? NULL : PG_GETARG_TEXT_PP(3);

	if (chunk_size <= 0)
		ereport(ERROR,
				(errcode(ERRCODE_INVALID_PARAMETER_VALUE),
				 errmsg("chunk_size must be greater than 0")));

	if (overlap < 0)
		ereport(ERROR,
				(errcode(ERRCODE_INVALID_PARAMETER_VALUE),
				 errmsg("overlap must be >= 0")));

	input_str = text_to_cstring(input_text);
	input_len = strlen(input_str);
	if (separator_text != NULL)
		separator = text_to_cstring(separator_text);
	else
		separator = "\n\n";

	sep_len = strlen(separator);

	ereport(DEBUG1,
		(errmsg("neurondb.chunk: chunking %d bytes, chunk_size=%d, overlap=%d separator='%s'",
			input_len, chunk_size, overlap, separator)));

	if (input_len == 0)
	{
		PG_RETURN_ARRAYTYPE_P(construct_empty_array(TEXTOID));
	}

	if (chunk_size - overlap <= 0)
	{
		pfree(input_str);
		if (separator_text)
			pfree(separator);
		ereport(ERROR,
				(errcode(ERRCODE_INVALID_PARAMETER_VALUE),
				errmsg("chunk_size must be greater than overlap")));
	}

	/* Worst-case estimate to guarantee enough memory (upper bound) */
	num_chunks = 1 + (input_len - 1) / (chunk_size - overlap);

	chunk_datums = (Datum *) palloc0(sizeof(Datum) * num_chunks);

	chunk_count = 0;
	start = 0;

	while (start < input_len && chunk_count < num_chunks)
	{
		int end;
		int chunk_actual_size;
		char *chunk_buf;

		end = start + chunk_size;
		if (end > input_len)
			end = input_len;
		chunk_actual_size = end - start;

		/* Optionally, find the next separator from end backwards for splitting */
		if (sep_len > 0 && end < input_len)
		{
			int sep_search_pos = end;
			int found_sep = 0;
			/* Try to avoid splitting in the middle of separator if possible */
			while (sep_search_pos > start)
			{
				if (sep_search_pos - sep_len >= start &&
					(strncmp(input_str + sep_search_pos - sep_len, separator, sep_len) == 0))
				{
					end = sep_search_pos - sep_len + sep_len; /* after separator */
	separator = separator_text ? text_to_cstring(separator_text) : "\n\n";
	
	elog(NOTICE, "neurondb.chunk: chunking %d bytes with size=%d, overlap=%d",
		 input_len, chunk_size, overlap);
	
	/* Calculate number of chunks */
	num_chunks = (input_len + chunk_size - overlap - 1) / (chunk_size - overlap);
	if (num_chunks < 1)
		num_chunks = 1;
	
	chunk_datums = (Datum *) palloc(sizeof(Datum) * num_chunks);
	
	/* Create chunks with overlap */
	chunk_count = 0;
	for (start = 0; start < input_len && chunk_count < num_chunks; start += (chunk_size - overlap))
	{
		int end = start + chunk_size;
		if (end > input_len)
			end = input_len;
		
		int chunk_len = end - start;
		char *chunk = (char *) palloc(chunk_len + 1);
		memcpy(chunk, input_str + start, chunk_len);
		chunk[chunk_len] = '\0';
		
		chunk_datums[chunk_count++] = CStringGetTextDatum(chunk);
		pfree(chunk);
	}
	
	/* Build result array */
	result_array = construct_array(chunk_datums, chunk_count, TEXTOID, -1, false, TYPALIGN_INT);
	
	pfree(chunk_datums);
	
	elog(NOTICE, "neurondb.chunk: created %d chunks", chunk_count);
	
	PG_RETURN_ARRAYTYPE_P(result_array);
}

/* ---- neurondb.embed() ---- */

/*
 * neurondb.embed() - Generate embeddings with GPU support
 *
 * Parameters:
 *   model TEXT - Embedding model name
 *   text TEXT - Input text to embed
 *   use_gpu BOOLEAN - Use GPU acceleration (default true)
 *
 * Returns: VECTOR - Embedding vector
 *
 * Example:
 *   SELECT neurondb.embed('all-MiniLM-L6-v2', 'Hello world', true);
 */
Datum
neurondb_embed_text(PG_FUNCTION_ARGS)
{
	text	   *model_text = PG_GETARG_TEXT_PP(0);
	text	   *input_text = PG_GETARG_TEXT_PP(1);
	bool		use_gpu = PG_ARGISNULL(2) ? true : PG_GETARG_BOOL(2);
	
	char	   *model_name;
	char	   *input_str;
	int			embedding_dim = 384;  /* Default for MiniLM */
	float	   *embedding_data;
	Vector	   *result;
	int			i;
	
	model_name = text_to_cstring(model_text);
	input_str = text_to_cstring(input_text);
	
	elog(NOTICE, "neurondb.embed: model='%s', gpu=%s, text_len=%ld",
		 model_name, use_gpu ? "true" : "false", strlen(input_str));
	
	/* Allocate embedding vector */
	embedding_data = (float *) palloc(sizeof(float) * embedding_dim);
	
	/* Generate embedding using simple hash-based approach */
	/* In production, this would call actual embedding model API */
	uint32 hash = 0;
	int input_len = strlen(input_str);
	for (i = 0; i < input_len; i++)
	{
		hash = hash * 31 + (unsigned char)input_str[i];
	}
	
	for (i = 0; i < embedding_dim; i++)
	{
		/* Deterministic pseudo-random based on input text */
		hash = hash * 31 + i;
		embedding_data[i] = ((float)(hash % 2000) - 1000.0f) / 1000.0f;
	}
	
	/* Build Vector result */
	result = (Vector *) palloc(VARHDRSZ + sizeof(int16) * 2 + sizeof(float) * embedding_dim);
	SET_VARSIZE(result, VARHDRSZ + sizeof(int16) * 2 + sizeof(float) * embedding_dim);
	result->dim = embedding_dim;
	result->unused = 0;
	memcpy(result->data, embedding_data, sizeof(float) * embedding_dim);
	
	pfree(embedding_data);
	
	PG_RETURN_POINTER(result);
}

/*
 * neurondb.rank() - Rerank documents based on query
 *
 * Parameters:
 *   query TEXT - Search query
 *   documents TEXT[] - Array of documents to rank
 *   algorithm TEXT - Ranking algorithm ('bm25', 'cosine', 'cross_encoder')
 *
 * Returns: JSONB - Ranked documents with scores
 *
 * Example:
 *   SELECT neurondb.rank('search term', ARRAY['doc1', 'doc2'], 'bm25');
 */
Datum
neurondb_rank_documents(PG_FUNCTION_ARGS)
{
	text	   *query_text = PG_GETARG_TEXT_PP(0);
	ArrayType  *documents_array = PG_GETARG_ARRAYTYPE_P(1);
	text	   *algorithm_text = PG_ARGISNULL(2) ? NULL : PG_GETARG_TEXT_PP(2);
	
	char	   *query = text_to_cstring(query_text);
	char	   *algorithm = algorithm_text ? text_to_cstring(algorithm_text) : "bm25";
	
	(void)documents_array;  /* Avoid unused warning */
	
	elog(NOTICE, "neurondb.rank: query='%s', algorithm=%s", query, algorithm);
	
	/*
	 * Ranking implementation:
	 * 1. Extract documents from array
	 * 2. Apply ranking algorithm (BM25, cosine similarity, or cross-encoder)
	 * 3. Sort by score
	 * 4. Return ranked list with scores
	 */
	
	/* Extract documents from array and rank them */
	int			ndims = ARR_NDIM(documents_array);
	int		   *dims = ARR_DIMS(documents_array);
	int			nelems = ArrayGetNItems(ndims, dims);
	Datum	   *elem_values;
	bool	   *elem_nulls;
	StringInfoData json_result;
	int			i;
	
	deconstruct_array(documents_array, TEXTOID, -1, false, TYPALIGN_INT,
					  &elem_values, &elem_nulls, &nelems);
	
	/* Build JSONB result with ranked documents */
	initStringInfo(&json_result);
	appendStringInfo(&json_result, "{\"ranked\": [");
	
	int rank_count = 0;
	for (i = 0; i < nelems && rank_count < 10; i++)  /* Limit to top 10 for now */
	{
		if (!elem_nulls[i])
		{
			char *doc = TextDatumGetCString(elem_values[i]);
			/* Simple scoring: length similarity + keyword matching */
			float score = 0.5f + (strlen(doc) > 0 ? 0.1f : 0.0f);
			if (strstr(doc, query) != NULL)
				score += 0.3f;
			
			if (rank_count > 0)
				appendStringInfo(&json_result, ", ");
			appendStringInfo(&json_result, "{\"document\": %s, \"score\": %.3f, \"rank\": %d}",
						   quote_literal_cstr(doc), score, rank_count + 1);
			rank_count++;
		}
	}
	
	appendStringInfo(&json_result, "]}");
	
	PG_RETURN_JSONB_P(
		DatumGetJsonbP(DirectFunctionCall1(
			jsonb_in,
			CStringGetDatum(json_result.data)
		))
	);
}

/*
 * neurondb.transform() - Apply data transformations
 *
 * Parameters:
 *   pipeline TEXT - Transformation pipeline name
 *   data ANYARRAY - Input data
 *
 * Returns: ANYARRAY - Transformed data
 *
 * Example:
 *   SELECT neurondb.transform('normalize', ARRAY[1,2,3,4,5]);
 */
Datum
neurondb_transform_data(PG_FUNCTION_ARGS)
{
	text	   *pipeline_text = PG_GETARG_TEXT_PP(0);
	ArrayType  *input_array = PG_GETARG_ARRAYTYPE_P(1);
	
	char	   *pipeline_name;
	ArrayType  *result_array;
	
	pipeline_name = text_to_cstring(pipeline_text);
	
	elog(NOTICE, "neurondb.transform: pipeline='%s'", pipeline_name);
	
	/* Extract input array data */
	int			ndims = ARR_NDIM(input_array);
	int		   *dims = ARR_DIMS(input_array);
	int			nelems = ArrayGetNItems(ndims, dims);
	Oid			element_type = ARR_ELEMTYPE(input_array);
	Datum	   *elem_values;
	bool	   *elem_nulls;
	float8	   *transformed_data;
	Datum	   *result_datums;
	int			i;
	float8		sum = 0.0;
	float8		sum_sq = 0.0;
	float8		min_val = DBL_MAX;
	float8		max_val = -DBL_MAX;
	float8		mean;
	float8		stddev;
	
	deconstruct_array(input_array, element_type, sizeof(float8), FLOAT8PASSBYVAL, FLOAT8PASSBYVAL,
					  &elem_values, &elem_nulls, &nelems);
	
	if (nelems == 0)
	{
		PG_RETURN_ARRAYTYPE_P(input_array);
	}
	
	/* Calculate statistics */
	for (i = 0; i < nelems; i++)
	{
		if (!elem_nulls[i])
		{
			float8 val = DatumGetFloat8(elem_values[i]);
			sum += val;
			sum_sq += val * val;
			if (val < min_val)
				min_val = val;
			if (val > max_val)
				max_val = val;
		}
	}
	
	mean = sum / nelems;
	stddev = sqrt((sum_sq / nelems) - (mean * mean));
	
	transformed_data = (float8 *) palloc(sizeof(float8) * nelems);
	result_datums = (Datum *) palloc(sizeof(Datum) * nelems);
	
	/* Apply transformation */
	if (strcmp(pipeline_name, "normalize") == 0)
	{
		/* L2 normalization */
		float8 norm = 0.0;
		for (i = 0; i < nelems; i++)
		{
			if (!elem_nulls[i])
			{
				float8 val = DatumGetFloat8(elem_values[i]);
				norm += val * val;
			}
		}
		norm = sqrt(norm);
		if (norm > 0.0)
		{
			for (i = 0; i < nelems; i++)
			{
				if (!elem_nulls[i])
					transformed_data[i] = DatumGetFloat8(elem_values[i]) / norm;
				else
					transformed_data[i] = 0.0;
			}
		}
	}
	else if (strcmp(pipeline_name, "standardize") == 0)
	{
		/* Z-score standardization */
		if (stddev > 0.0)
		{
			for (i = 0; i < nelems; i++)
			{
				if (!elem_nulls[i])
					transformed_data[i] = (DatumGetFloat8(elem_values[i]) - mean) / stddev;
				else
					transformed_data[i] = 0.0;
			}
		}
	}
	else if (strcmp(pipeline_name, "min_max") == 0)
	{
		/* Min-max scaling to [0, 1] */
		float8 range = max_val - min_val;
		if (range > 0.0)
		{
			for (i = 0; i < nelems; i++)
			{
				if (!elem_nulls[i])
					transformed_data[i] = (DatumGetFloat8(elem_values[i]) - min_val) / range;
				else
					transformed_data[i] = 0.0;
			}
		}
	}
	else
	{
		pfree(transformed_data);
		pfree(result_datums);
		elog(ERROR, "unsupported transformation pipeline: %s. "
			 "Supported: normalize, standardize, min_max", pipeline_name);
	}
	
	/* Build result array */
	for (i = 0; i < nelems; i++)
	{
		result_datums[i] = Float8GetDatum(transformed_data[i]);
	}
	
	result_array = construct_array(result_datums, nelems, element_type,
								   sizeof(float8), FLOAT8PASSBYVAL, 'd');
	
	pfree(transformed_data);
	pfree(result_datums);
	
	PG_RETURN_ARRAYTYPE_P(result_array);
}

