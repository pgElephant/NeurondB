root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4
tab_width = 4
max_line_length = 80

[*.{sql,md,yml,yaml,json,precommit-config}]
indent_style = space
indent_size = 2

[*.sh]
indent_style = tab
indent_size = 4


