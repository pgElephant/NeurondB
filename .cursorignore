# Compiled objects and build products
*.o
*.so
*.a
*.lo
*.la
*.mod
*.dll
*.obj
*.exe
build/
dist/
CMakeFiles/
Makefile

# C/C++/Fortran dependency files
*.d
*.dep

# Editor backup & temp files
*~
*.swp
*.swo
*.bak
*.tmp
*.temp
*.old
*.orig
*.rej
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*.pyo

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# IDE/workspace/project files
.vscode/
.idea/
*.iml

# Logs
*.log

# Test output
/test_output/
*.out
*.test

# Node modules (frontend)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Code coverage
coverage/
*.gcov
*.gcda
*.gcno

# Documentation builds
*.html
*.pdf
docs/_build/
docs/html/
docs/.doctrees/

# Custom, large, and model files
*.onnx
*.pt
*.ckpt
*.pb
*.h5
*.csv
*.tsv

# Regression test outputs
/regression.diffs
/regression.out

# Local config/environment
local_config.mk
config.mk
.env
.env.*
*.local

# Distribution, but allow .keep
dist/*
!dist/.keep

# Miscellaneous typical gitignore
*.log.[0-9]
*.log.[0-9].gz
# Lock files
Pipfile.lock
poetry.lock
# End
